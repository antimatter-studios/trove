<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened runtime is enforced for Developer-ID signed apps (a
       prerequisite for notarization). Library validation is disabled so the
       WebKit/system frameworks the Tauri webview loads at launch are not
       rejected for having a different Team ID than this binary. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
