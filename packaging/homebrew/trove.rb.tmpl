      sha256 "@SHA_DARWIN_X86_64@"
    end
  end

  on_linux do
    on_arm do
      url "https://github.com/antimatter-studios/trove/releases/download/v#{version}/trove-#{version}-linux-arm64.tar.gz"
      sha256 "@SHA_LINUX_ARM64@"
    end
    on_intel do
      url "https://github.com/antimatter-studios/trove/releases/download/v#{version}/trove-#{version}-linux-x86_64.tar.gz"
      sha256 "@SHA_LINUX_X86_64@"
    end
  end

  def install
    bin.install "trove", "troved"
  end

  def caveats
    <<~EOS
      Two binaries installed:
        trove   — CLI client
        troved  — long-running daemon (auto-spawned by trove on first use)

      Quickstart:
        trove unlock ~/path/to/your.kdbx     # starts troved if needed
        export SSH_AUTH_SOCK="$(trove agent socket)"
        ssh-add -L

      For GPG signing (git commit -S):
        ln -sf "$(trove gpg-agent socket)" "${GNUPGHOME:-$HOME/.gnupg}/S.gpg-agent"

      Windows: run trove inside WSL2 (a real Linux environment). This Linux
      build works there as-is; bridging the agent socket to native-Windows
      clients needs a relay such as npiperelay.

      Full quickstart + threat model:
        https://github.com/antimatter-studios/trove#quickstart
    EOS
